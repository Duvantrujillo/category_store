# ─── DESARROLLO ───────────────────────────────────────────────
# Copia este archivo a .env y completa los valores reales.
# Para producción cambia estas variables:
#   VITE_API_URL          → https://tu-backend.com
#   VITE_EPAYCO_TEST      → false
#   VITE_EPAYCO_WEBHOOK_URL → https://tu-backend.com/webhook/create
#   (en desarrollo se omite VITE_EPAYCO_WEBHOOK_URL; el código usa VITE_API_URL/webhook/create)

VITE_API_URL=http://localhost:3000
VITE_DEPARTMENTS_API_URL=https://api-colombia.com/api/v1
VITE_WHATSAPP_NUMBER=573001234567
VITE_EPAYCO_PUBLIC_KEY=tu_public_key_de_epayco
VITE_EPAYCO_TEST=true
VITE_EPAYCO_WEBHOOK_URL=
