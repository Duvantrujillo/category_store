generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url = env("DATABASE_URL")
}

enum UserStatus {
  active
  inactive
  blocked
}

model User {
  id       Int        @id @default(autoincrement())
  name     String
  email    String     @unique
  password String
  roleId   Int
  status   UserStatus @default(active)
  role     Role       @relation(fields: [roleId], references: [id])
  carts             Cart[]
  orders            Order[]
  notifications     Notification[]
  registeredReturns ReturnRequest[]  @relation("ReturnRegisteredBy")
  approvedReturns   ReturnRequest[]  @relation("ReturnApprovedBy")
  processedRefunds  Refund[]         @relation("RefundProcessedBy")
  shipmentUpdates   ShipmentHistory[] @relation("ShipmentUpdatedBy")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Role {
  id          Int     @id @default(autoincrement())
  name        String
  description String
  status      Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  permissions RolePermission[]
  users       User[]
}

model Permission {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  roles       RolePermission[]
}

model RolePermission {
  roleId       Int
  permissionId Int
  isActive     Boolean @default(true)

  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])

  @@index([roleId])
  @@index([permissionId])
}


model FormResponse{
  id String @id @default(cuid())
  firstName String
  lastName String
  documentNumber String 
  phoneNumber String
  departament String
  municipality String
  address String
  additionalDetails String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category{
  id Int @id @default(autoincrement())
  parentId Int?
  parent Category? @relation("CategoryHierarcy",fields: [parentId], references: [id],onDelete: SetNull)
 name String
 slug String @unique
 description String? @db.Text
 imageUrl String?
 isActive Boolean @default(true)
 sortOrder Int
 createdAt DateTime @default(now())
 updatedAt DateTime @updatedAt
 children Category[] @relation("CategoryHierarcy")
 products Product[]
 discountCodes DiscountCodeCategory[]
 @@index([parentId])
 @@index([isActive,sortOrder])
 @@index([isActive, name])
}


model Attribute {
  id Int @id @default(autoincrement())

  name String
  slug String @unique
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  values AttributeValue[]
}

model AttributeValue {
  id Int @id @default(autoincrement())
  value String
  slug String?
  attributeId Int
  attribute Attribute @relation(fields: [attributeId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  productVariants ProductVariantAttribute[]
  @@unique([attributeId, value])
  @@index([attributeId])
  @@index([value(length: 100)])
}

model Brand {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  description String?  @db.Text
  logoUrl     String?
  isActive    Boolean  @default(true)
  products Product[]
  discountCodes DiscountCodeBrand[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([isActive, name])
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  DRAFT
}
model Product {
  id Int @id @default(autoincrement())
  categoryId Int
  brandId Int?
  category Category @relation(fields: [categoryId], references: [id])
  brand Brand? @relation(fields: [brandId], references: [id])
  name String
  slug String @unique
  description String? @db.Text
   mainImage String?
  status ProductStatus @default(DRAFT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  variants  ProductVariant[]
  discountCodes DiscountCodeProduct[]
  bundleItems ProductBundleItem[]
  @@index([categoryId])
  @@index([brandId])
  @@index([status])
  @@index([status, name])
}


model ProductVariant {
  id Int @id @default(autoincrement())
  productId Int
  product Product @relation(fields: [productId], references: [id])
  sku String? @unique
  barcode String?
  price         Decimal @db.Decimal(10,2)
  stock         Int     @default(0)
  reservedStock Int     @default(0)
  isDefault Boolean @default(false)
  isActive Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  attributes ProductVariantAttribute[]
   images ProductVariantImage[]
   cartItems    CartItem[]
   orderItems   OrderItem[]
   wishlistItems WishlistItem[]
   bundleItems ProductBundleItem[]
   orderBundleItemDetails OrderBundleItemDetail[]
   cartBundleSelections CartBundleItemSelection[]
  @@index([productId])
  @@index([sku])
  @@index([barcode])
  @@index([isActive, stock])
}

model ProductVariantAttribute {
  id Int @id @default(autoincrement())
  productVariantId Int
  attributeValueId Int
  productVariant ProductVariant @relation(fields: [productVariantId], references: [id])
  attributeValue AttributeValue @relation(fields: [attributeValueId], references: [id])
  @@unique([productVariantId, attributeValueId])
  @@index([productVariantId])
  @@index([attributeValueId])
}


model ProductVariantImage {
  id Int @id @default(autoincrement())
  productVariantId Int
  productVariant ProductVariant @relation(fields: [productVariantId], references: [id])
  imageUrl String
  slot Int  // 1 a 5 (posición en los cuadros del front)
  createdAt DateTime @default(now())
  @@index([productVariantId])
  @@unique([productVariantId, slot])
}

model ProductBundle {
  id Int @id @default(autoincrement())

  name String
  slug String @unique
  description String? @db.Text

  mainImage String?

  price Decimal @db.Decimal(10,2)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items ProductBundleItem[]
  cartItems CartBundleItem[]
  orderItems OrderBundleItem[]

  @@index([isActive])
  @@index([name])
}

model ProductBundleItem {
  id Int @id @default(autoincrement())

  bundleId Int
  productId Int
  // Si es null, el componente es "libre": el cliente elige cuál variante de
  // `product` quiere al agregar el combo al carrito. Si tiene valor, es una
  // variante "fija" elegida por el admin y el cliente no puede cambiarla.
  productVariantId Int?

  quantity Int @default(1)

  bundle ProductBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
  productVariant ProductVariant? @relation(fields: [productVariantId], references: [id])

  cartSelections CartBundleItemSelection[]

  @@unique([bundleId, productId])

  @@index([bundleId])
  @@index([productId])
  @@index([productVariantId])
}

enum CartStatus{
  ACTIVE
  COMPLETED
  ABANDONED
}
model Cart {
  id Int@id @default(autoincrement())
  uuid String @unique @default(uuid())
  userId Int?
  user User? @relation(fields: [userId],references: [id])
  status CartStatus @default(ACTIVE)
  items CartItem[]
  bundleItems CartBundleItem[]
  wishlist Wishlist?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model CartItem {
  id               Int @id @default(autoincrement())
  cartId           Int
  productVariantId Int
  quantity         Int @default(1)
  cart             Cart           @relation(fields: [cartId], references: [id])
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])
  @@unique([cartId, productVariantId])
  @@index([cartId])
}

model CartBundleItem {
  id Int @id @default(autoincrement())

  cartId Int
  bundleId Int

  quantity Int @default(1)

  cart Cart @relation(fields: [cartId], references: [id])
  bundle ProductBundle @relation(fields: [bundleId], references: [id])

  // Variante elegida por el cliente para cada componente "libre" del combo
  // (los componentes "fijos" no necesitan fila acá, ya está en ProductBundleItem).
  selections CartBundleItemSelection[]

  @@unique([cartId, bundleId])

  @@index([cartId])
  @@index([bundleId])
}

model CartBundleItemSelection {
  id Int @id @default(autoincrement())

  cartBundleItemId Int
  // A qué "slot"/componente del combo corresponde esta elección.
  productBundleItemId Int
  productVariantId Int

  cartBundleItem CartBundleItem @relation(fields: [cartBundleItemId], references: [id], onDelete: Cascade)
  productBundleItem ProductBundleItem @relation(fields: [productBundleItemId], references: [id], onDelete: Cascade)
  productVariant ProductVariant @relation(fields: [productVariantId], references: [id])

  @@unique([cartBundleItemId, productBundleItemId])

  @@index([cartBundleItemId])
  @@index([productBundleItemId])
  @@index([productVariantId])
}

model Wishlist {
  id        Int            @id @default(autoincrement())
  cartId    Int            @unique
  cart      Cart           @relation(fields: [cartId], references: [id])
  items     WishlistItem[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model WishlistItem {
  id               Int            @id @default(autoincrement())
  wishlistId       Int
  productVariantId Int
  wishlist         Wishlist       @relation(fields: [wishlistId], references: [id])
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])
  @@unique([wishlistId, productVariantId])
  @@index([wishlistId])
}

enum OrderStatus {
   
  PENDING
  PAID
  CANCELLED
  REFUNDED
}
model Order {
  id Int @id @default(autoincrement())
  orderNumber    String  @unique
  idempotencyKey String? @unique
  // UUID del carrito anónimo que creó este pedido (frontend/src/pages/public/Home/hooks/usePublicCart.js).
  // Sirve como prueba de "dueño" del pedido en los endpoints públicos de
  // pago: mucho más difícil de adivinar que el orderNumber solo.
  cartUuid String?
  userId Int?
  user User? @relation(fields: [userId], references: [id])
  firstName String
  lastName String
  documentNumber String
  email String?
  phoneNumber String
  departament String
  municipality String
  address String
  additionalDetails String?
  status OrderStatus @default(PENDING)
  subtotal     Decimal @db.Decimal(12,2)
  shippingCost Decimal @db.Decimal(12,2) @default(11000)
  total        Decimal @db.Decimal(12,2)
  currency String @default("COP")
  // Cupón validado al crear el pedido (el monto ya está descontado en `total`
  // desde la creación). El uso "oficial" que cuenta para el maxUses del cupón
  // (DiscountCodeUsage) solo se registra cuando el pago se confirma (PAID) —
  // ver `confirmDiscountUsage` en discount_code.controller.js.
  discountCodeId Int?
  discountCode DiscountCode? @relation(fields: [discountCodeId], references: [id])
  discountAmount Decimal @db.Decimal(12,2) @default(0)
  items OrderItem[]
  bundleItems OrderBundleItem[]
  returns ReturnRequest[]
  payment Payment?
  shipment Shipment?
  discountUsages DiscountCodeUsage[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderItem {
  id               Int            @id @default(autoincrement())
  orderId          Int
  order            Order          @relation(fields: [orderId], references: [id])
  productVariantId Int
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])
  productName      String        
  quantity         Int
  unitPrice        Decimal @db.Decimal(12,2)
  subtotal         Decimal @db.Decimal(12,2)
  returnItems ReturnItem[]
  createdAt        DateTime @default(now())
}

model OrderBundleItem {
  id Int @id @default(autoincrement())

  orderId Int
  bundleId Int

  order Order @relation(fields: [orderId], references: [id])
  bundle ProductBundle @relation(fields: [bundleId], references: [id])

  bundleName String

  quantity Int

  unitPrice Decimal @db.Decimal(12,2)

  subtotal Decimal @db.Decimal(12,2)

  createdAt DateTime @default(now())

  items OrderBundleItemDetail[]

  @@index([orderId])
  @@index([bundleId])
}

model OrderBundleItemDetail {
  id Int @id @default(autoincrement())

  orderBundleItemId Int

  productVariantId Int

  orderBundleItem OrderBundleItem @relation(fields: [orderBundleItemId], references: [id], onDelete: Cascade)

  productVariant ProductVariant @relation(fields: [productVariantId], references: [id])

  productName String

  quantity Int

  createdAt DateTime @default(now())

  @@index([orderBundleItemId])
  @@index([productVariantId])
}


enum PaymentStatus {
  PENDING
  APPROVED
  DECLINED
  VOIDED
  ERROR
}
model Payment {
  id              Int            @id @default(autoincrement())
  orderId         Int            @unique
  order           Order          @relation(fields: [orderId], references: [id])
  provider        String         // "epayco"
  reference       String         @unique
  transactionId   String?
  amount          Decimal        @db.Decimal(12,2)
  currency        String         @default("COP")
  status          PaymentStatus  @default(PENDING)
  paymentMethod   String?
  refunds Refund[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}



enum PaymentMethodType {
  DIGITAL_WALLET
  BANK_TRANSFER
  CREDIT_CARD
  INTERNATIONAL
  CASH
}

model PaymentMethod {
  id       Int               @id @default(autoincrement())
  name     String
  type     PaymentMethodType
  isActive Boolean           @default(true)
}

//Reembolsos y devoluciones

enum ReturnStatus {
  PENDING
  APPROVED
  REJECTED
  RECEIVED
  COMPLETED
}

enum ReturnResolution {
  REFUND
  EXCHANGE
  STORE_CREDIT
}

model ReturnRequest {
  id Int @id @default(autoincrement())

  orderId Int
  order Order @relation(fields: [orderId], references: [id])

  status ReturnStatus @default(PENDING)

  resolution ReturnResolution?

  reason String?

  registeredById Int?
  registeredBy   User? @relation("ReturnRegisteredBy", fields: [registeredById], references: [id])

  approvedById Int?
  approvedBy   User? @relation("ReturnApprovedBy", fields: [approvedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items ReturnItem[]
  refunds Refund[]

  @@index([orderId])
  @@index([status])
  @@index([registeredById])
  @@index([approvedById])
}





model ReturnItem {
  id Int @id @default(autoincrement())

  returnRequestId Int
  returnRequest ReturnRequest @relation(fields: [returnRequestId], references: [id])

  orderItemId Int
  orderItem OrderItem @relation(fields: [orderItemId], references: [id])

  quantity Int

  createdAt DateTime @default(now())
  @@index([returnRequestId])
  @@index([orderItemId])
@@unique([returnRequestId, orderItemId])
}



enum RefundStatus {
  PENDING
  PROCESSED
  FAILED
}

model Refund {
  id Int @id @default(autoincrement())

  returnRequestId Int
  returnRequest ReturnRequest @relation(fields: [returnRequestId], references: [id])
  paymentId Int
  payment Payment @relation(fields: [paymentId], references: [id])
  amount Decimal @db.Decimal(12,2)
  status RefundStatus @default(PENDING)
  method String?
  reference String?
  paidAt DateTime?

  processedById Int?
  processedBy   User? @relation("RefundProcessedBy", fields: [processedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([returnRequestId])
  @@index([paymentId])
  @@index([processedById])
}



enum ShipmentStatus {
  CREATED
  PREPARING
  SHIPPED
  DELIVERED
  RETURNED
}

enum Carrier {
  SERVIENTREGA
  INTERRAPIDISIMO
  COORDINADORA
  ENVIA
}

model Shipment {
  id Int @id @default(autoincrement())

  orderId Int @unique
  order Order @relation(fields: [orderId], references: [id])

  status ShipmentStatus @default(CREATED)

  trackingNumber String?

  carrier Carrier?

  shippedAt DateTime?
  deliveredAt DateTime?

  history ShipmentHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}


model ShipmentHistory {
  id Int @id @default(autoincrement())

  shipmentId Int
  shipment Shipment @relation(fields: [shipmentId], references: [id])

  status ShipmentStatus

  note String?

  updatedById Int?
  updatedBy   User? @relation("ShipmentUpdatedBy", fields: [updatedById], references: [id])

  createdAt DateTime @default(now())

  @@index([shipmentId])
  @@index([updatedById])
}


enum NotificationType {
  ORDER_CREATED
  ORDER_PAID
  ORDER_CANCELLED

  PAYMENT_DECLINED

  SHIPMENT_CREATED

  RETURN_CREATED
  RETURN_APPROVED
  RETURN_REJECTED
  RETURN_COMPLETED

  REFUND_PROCESSED

  LOW_STOCK
  OUT_OF_STOCK
}

model Notification {
  id Int @id @default(autoincrement())

  userId Int
  user User @relation(fields: [userId], references: [id])

  type NotificationType

  title String
  message String

  actionUrl String?

  isRead Boolean @default(false)
  readAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, isRead])
}

model Banner {
  id        Int      @id @default(autoincrement())
  title     String
  imageUrl  String
  link      String?
  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(true)
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum DiscountType {
  PERCENTAGE
  FIXED
  FREE_SHIPPING
}

model DiscountCode {
  id Int @id @default(autoincrement())

  code String @unique

  description String?

  type DiscountType

  value Decimal @db.Decimal(10,2)

  minimumPurchase Decimal @db.Decimal(12,2) @default(0)

  maxUses Int?

  startsAt DateTime

  expiresAt DateTime

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  usages DiscountCodeUsage[]
  orders Order[]

  products DiscountCodeProduct[]
  categories DiscountCodeCategory[]
  brands DiscountCodeBrand[]

  @@index([code])
  @@index([isActive])
  @@index([startsAt])
  @@index([expiresAt])
}

model DiscountCodeProduct {
  id Int @id @default(autoincrement())

  discountCodeId Int
  productId Int

  discountCode DiscountCode @relation(fields: [discountCodeId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())

  @@unique([discountCodeId, productId])
  @@index([discountCodeId])
  @@index([productId])
}

model DiscountCodeCategory {
  id Int @id @default(autoincrement())

  discountCodeId Int
  categoryId Int

  discountCode DiscountCode @relation(fields: [discountCodeId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])

  createdAt DateTime @default(now())

  @@unique([discountCodeId, categoryId])
  @@index([discountCodeId])
  @@index([categoryId])
}

model DiscountCodeBrand {
  id Int @id @default(autoincrement())

  discountCodeId Int
  brandId Int

  discountCode DiscountCode @relation(fields: [discountCodeId], references: [id], onDelete: Cascade)
  brand Brand @relation(fields: [brandId], references: [id])

  createdAt DateTime @default(now())

  @@unique([discountCodeId, brandId])
  @@index([discountCodeId])
  @@index([brandId])
}

model DiscountCodeUsage {

  id Int @id @default(autoincrement())

  discountCodeId Int
  orderId Int

  discountCode DiscountCode @relation(fields: [discountCodeId], references: [id])

  order Order @relation(fields: [orderId], references: [id])

  amount Decimal @db.Decimal(12,2)

  createdAt DateTime @default(now())

  @@unique([discountCodeId, orderId])

  @@index([discountCodeId])

  @@index([orderId])

}