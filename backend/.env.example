# Copia este archivo a .env y completa los valores reales.
# NUNCA subas el .env real (con secretos) al repositorio.

# ─── Base de datos ─────────────────────────────────────────────
DATABASE_URL="mysql://usuario:contraseña@localhost:3306/category_db"

# ─── Servidor ──────────────────────────────────────────────────
PORT=3000
# URL pública del propio backend (usada para armar links en emails, etc.)
APP_URL=http://localhost:3000
# Origen permitido por CORS — en producción es obligatorio, si falta se
# bloquea todo origen por seguridad (ver app.js).
FRONTEND_URL=http://localhost:5173

# ─── Autenticación ─────────────────────────────────────────────
# Secreto para firmar los JWT de sesión — usa un valor largo y aleatorio,
# nunca lo reutilices entre entornos (dev/staging/prod).
JWT_SECRET=

# ─── Email transaccional (Resend) ─────────────────────────────
RESEND_API_KEY=
EMAIL_FROM="WowBeauty <pedidos@tu-dominio.com>"

# ─── Pasarela de pago (ePayco) ─────────────────────────────────
EPAYCO_CUST_ID=
EPAYCO_P_KEY=
EPAYCO_PUBLIC_KEY=
EPAYCO_PRIVATE_KEY=
